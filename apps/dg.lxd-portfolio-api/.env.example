# Copy to .env and fill in your values — never commit .env to version control

# SQLite (default, zero-setup) or swap for a full PostgreSQL URL:
#   postgresql+asyncpg://user:pass@localhost:5432/portfolio
DATABASE_URL=sqlite+aiosqlite:///./contact_submissions.db

# Outbound SMTP — use an app password, not your account password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# Destination inbox for contact-form alerts
ADMIN_EMAIL=admin@yourdomain.com

# Comma-separated list of allowed frontend origins (no trailing slash)
# JSON array (required by pydantic-settings for list fields)
CORS_ORIGINS=["http://localhost:5173","https://yourdomain.com"]
