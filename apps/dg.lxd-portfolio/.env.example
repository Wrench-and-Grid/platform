# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.

# CloudFront distribution URL (no trailing slash).
# Get this from AWS Console → CloudFront → your distribution → Domain name.
# Example: https://d1abc123xyz.cloudfront.net
# Or your custom domain: https://cdn.yourdomain.com
VITE_CDN_BASE_URL=https://cdn.yourdomain.com
