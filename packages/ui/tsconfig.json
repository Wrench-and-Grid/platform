{
  "extends": "../config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
